{
  "family": "taskflow-task",
  "networkMode": "awsvpc",
  "requiresCompatibilities": [
    "FARGATE"
  ],
  "cpu": "1024",
  "memory": "2048",
  "taskRoleArn": "arn:aws:iam::343227608039:role/LabRole",
  "executionRoleArn": "arn:aws:iam::343227608039:role/LabRole",
  "containerDefinitions": [
    {
      "name": "db",
      "image": "postgres:16-alpine",
      "cpu": 256,
      "memory": 512,
      "portMappings": [
        {
          "containerPort": 5432,
          "hostPort": 5432,
          "protocol": "tcp"
        }
      ],
      "essential": true,
      "environment": [
        {
          "name": "POSTGRES_DB",
          "value": "taskflow_db"
        },
        {
          "name": "POSTGRES_USER",
          "value": "taskflow_user"
        },
        {
          "name": "POSTGRES_PASSWORD",
          "value": "taskflow_password"
        }
      ],
      "healthCheck": {
        "command": [
          "CMD-SHELL",
          "pg_isready -U taskflow_user -d taskflow_db"
        ],
        "interval": 5,
        "timeout": 5,
        "retries": 5,
        "startPeriod": 10
      },
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/taskflow",
          "awslogs-region": "us-east-1",
          "awslogs-stream-prefix": "db",
          "awslogs-create-group": "true"
        }
      }
    },
    {
      "name": "backend",
      "image": "343227608039.dkr.ecr.us-east-1.amazonaws.com/taskflow-backend:latest",
      "cpu": 512,
      "memory": 1024,
      "portMappings": [
        {
          "containerPort": 8080,
          "hostPort": 8080,
          "protocol": "tcp"
        }
      ],
      "essential": true,
      "dependsOn": [
        {
          "containerName": "db",
          "condition": "HEALTHY"
        }
      ],
      "environment": [
        {
          "name": "DB_HOST",
          "value": "127.0.0.1"
        },
        {
          "name": "DB_PORT",
          "value": "5432"
        },
        {
          "name": "DB_NAME",
          "value": "taskflow_db"
        },
        {
          "name": "DB_USER",
          "value": "taskflow_user"
        },
        {
          "name": "DB_PASSWORD",
          "value": "taskflow_password"
        }
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/taskflow",
          "awslogs-region": "us-east-1",
          "awslogs-stream-prefix": "backend",
          "awslogs-create-group": "true"
        }
      }
    },
    {
      "name": "frontend",
      "image": "343227608039.dkr.ecr.us-east-1.amazonaws.com/taskflow-frontend:latest",
      "cpu": 256,
      "memory": 512,
      "portMappings": [
        {
          "containerPort": 80,
          "hostPort": 80,
          "protocol": "tcp"
        }
      ],
      "essential": true,
      "dependsOn": [
        {
          "containerName": "backend",
          "condition": "START"
        }
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/taskflow",
          "awslogs-region": "us-east-1",
          "awslogs-stream-prefix": "frontend",
          "awslogs-create-group": "true"
        }
      }
    }
  ]
}
